# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Secrets — never bake into the image
.env
.env.*
!.env.example

# Version control
.git/
.gitignore

# Docs (not needed at runtime)
*.md
docs/
reports/

# Dev / test data
data/
tests/

# Docker meta (don't copy compose files / Dockerfile into the image itself)
docker-compose*.yml
Dockerfile
.dockerignore
