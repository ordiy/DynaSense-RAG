# ═══════════════════════════════════════════════════════════════════════
#  DynaSense-RAG — Environment Configuration Template
#  Copy this file:  cp .env.example .env
#  Fill in values marked (required) before running:  docker compose up --build
# ═══════════════════════════════════════════════════════════════════════

# ── Google Cloud / Vertex AI ────────────────────────────────  (required)
# GCP project that has Vertex AI API enabled.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Absolute path on the HOST machine to your Service Account JSON key.
# docker-compose.yml mounts this file into the container automatically.
# Required role: "Vertex AI User".
GCP_SA_KEY_FILE=/path/to/your/service-account-key.json

# ── Jina AI ─────────────────────────────────────────────────  (required)
# Semantic chunking (segment.jina.ai) and cross-encoder reranking
# (api.jina.ai/v1/rerank, model: jina-reranker-v2-base-multilingual).
# Without a key both calls degrade gracefully but quality drops.
JINA_API_KEY=jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LangSmith observability ─────────────────────────────────  (optional)
# LangChain / LangGraph trace logging — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=DynaSense-RAG

# LangGraph: log each node step when using stream(stream_mode="values")
# See docs/langgraph_stream_log.md
LANGGRAPH_STREAM_LOG=false

# ── Query guardrails ─────────────────────────────────────────  (optional)
# Block queries containing credit-card-like numbers or 18-digit Chinese IDs.
# BLOCK_SUSPECT_PII=true

# ── Debug API ────────────────────────────────────────────────  (optional)
# Exposes read-only /api/debug/* browser. Set false when publicly deployed.
DEBUG_DATA_API=true

# ── RAG feature flags ────────────────────────────────────────  (optional)
# HYBRID_RAG_ENABLED=true      # false → vector-only LangGraph path
# SKIP_GRAPH_INGEST=false      # true → skip LLM triple extraction on upload

# ── Graph backend ────────────────────────────────────────────  (optional)
# GRAPH_BACKEND=age            # age | relational  (relational = kg_triple fallback)
# AGE_GRAPH_NAME=map_rag_kg

# ── Retrieval tuning ─────────────────────────────────────────  (optional)
# RAG_VECTOR_RERANK_TOP_N=5
# HYBRID_FUSION_TOP_N=5
# HYBRID_BM25_TOP_CHILD=12
# HYBRID_DENSE_K=10
# HYBRID_RERANK_POOL_SIZE=40

# ── Session / upload limits ──────────────────────────────────  (optional)
# MAX_UPLOAD_BYTES=2097152         # 2 MB per document (default)
# CHAT_SESSION_TTL_SECONDS=3600
# PG_POOL_MAX_SIZE=10
