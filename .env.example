# Copy to .env (never commit .env). Used by local tools / shells.
JINA_API_KEY=

# Read-only /api/debug/* for LanceDB + Neo4j UI (set false in production if exposed).
DEBUG_DATA_API=true

# LangSmith observability (https://docs.langchain.com/langsmith/observability)
# Create API key: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
# Optional: group traces in the LangSmith UI
LANGCHAIN_PROJECT=DynaSense-RAG

# LangGraph: log each step when using stream(stream_mode="values") — see docs/langgraph_stream_log.md
LANGGRAPH_STREAM_LOG=false
